---
import '../styles/global.css';
import { t } from '../i18n';

interface Props {
  title?: string;
  description?: string;
}

const { title, description = t('site.description') } = Astro.props;
const pageTitle = title ? `${title} — ${t('site.title')}` : t('site.title');
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen bg-white text-gray-900 antialiased dark:bg-gray-950 dark:text-gray-100">
    <!-- Шапка по стандарту: слева название и краткое описание, справа навигация; фиксированная высота -->
    <header class="border-b border-gray-200 dark:border-gray-800">
      <nav class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-3">
        <div class="min-w-0">
          <a href="/" class="block truncate text-sm font-bold">{t('site.title')}</a>
          <p class="mt-0.5 hidden truncate text-[11px] font-medium text-[#898989] sm:block">
            {t('site.description')}
          </p>
        </div>
        <a
          href="/methodology"
          class="shrink-0 text-sm text-gray-600 hover:underline dark:text-gray-400"
        >
          {t('nav.methodology')}
        </a>
      </nav>
    </header>
    <main class="mx-auto max-w-5xl px-4 py-6">
      <slot />
    </main>
    <footer class="border-t border-gray-200 dark:border-gray-800">
      <div class="mx-auto max-w-5xl space-y-1 px-4 py-4 text-xs text-gray-500 dark:text-gray-400">
        <p>{t('footer.license')}</p>
        <!-- TODO: ссылка на репозиторий после публикации на GitHub -->
      </div>
    </footer>
  </body>
</html>
