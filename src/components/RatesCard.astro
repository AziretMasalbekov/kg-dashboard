---
import Sparkline from './Sparkline.astro';
import { t } from '../i18n';
import {
  formatDateRu,
  formatDelta,
  formatValue,
  latestWithDelta,
  type MetricPayload,
} from '../lib/metrics';

import usd from '../../data/kgs_usd.json';
import eur from '../../data/kgs_eur.json';
import rub from '../../data/kgs_rub.json';
import kzt from '../../data/kgs_kzt.json';

const featured = usd as MetricPayload;
const rest: [string, MetricPayload][] = [
  ['EUR', eur as MetricPayload],
  ['RUB', rub as MetricPayload],
  ['KZT', kzt as MetricPayload],
];

const main = latestWithDelta(featured.series);
// дельта без цветового кодирования: направление показывает только знак
const deltaClass = (_d: number | null) => 'text-gray-500 dark:text-gray-400';
---

<article class="rounded-lg border border-gray-200 p-4 dark:border-gray-800">
  <!-- заголовок блока слева, иконка интерактивности справа (по стандарту) -->
  <h2 class="flex items-center justify-between gap-2 text-[13px] font-bold">
    <a href="/metric/kgs_usd" class="hover:underline">
      {t('metric.kgs_rates.title')}
    </a>
    <a href="/metric/kgs_usd" aria-hidden="true" tabindex="-1" class="text-gray-400">›</a>
  </h2>

  <p class="mt-2 flex items-baseline gap-2">
    <span class="text-3xl font-semibold tabular-nums">{formatValue(main.value)}</span>
    <span class="text-sm text-gray-500 dark:text-gray-400">{featured.unit}</span>
    {
      main.delta != null && (
        <span class={`text-sm tabular-nums ${deltaClass(main.delta)}`}>
          {formatDelta(main.delta)}
        </span>
      )
    }
  </p>

  <Sparkline series={featured.series} id="kgs-usd" />

  <ul class="mt-3 space-y-1 border-t border-gray-100 pt-3 text-sm dark:border-gray-800">
    {
      rest.map(([code, m]) => {
        const cur = latestWithDelta(m.series);
        return (
          <li class="flex items-baseline justify-between gap-2">
            <span class="text-gray-600 dark:text-gray-400">{code}</span>
            <span class="tabular-nums">
              {formatValue(cur.value)}
              {cur.delta != null && (
                <span class={`ml-1 text-xs ${deltaClass(cur.delta)}`}>
                  {formatDelta(cur.delta)}
                </span>
              )}
            </span>
          </li>
        );
      })
    }
  </ul>

  <p class="mt-3 text-xs text-gray-500 dark:text-gray-400">
    {t('metric.kgs_rates.explain')}
  </p>

  <p class="mt-2 text-xs text-gray-500 dark:text-gray-400">
    <a href={featured.source_url} rel="noopener" class="underline">
      {t('card.source')}: {featured.source_name}
    </a>
    · {t('card.data_as_of')} {formatDateRu(featured.data_date)}
  </p>
</article>
