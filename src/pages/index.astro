---
import Base from '../layouts/Base.astro';
import NscCard from '../components/NscCard.astro';
import RatesCard from '../components/RatesCard.astro';
import { t } from '../i18n';

const nscMetrics = [
  'nsc_cpi',
  'nsc_wage',
  'nsc_unemployment',
  'nsc_poverty',
  'nsc_subsistence',
  'nsc_population',
];
---

<Base>
  <h1 class="sr-only">{t('nav.dashboard')}</h1>
  <!-- Сетка карточек метрик; карточки подключаются по мере готовности парсеров -->
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {nscMetrics.map((slug) => <NscCard slug={slug} />)}
    <RatesCard />
  </div>
</Base>
